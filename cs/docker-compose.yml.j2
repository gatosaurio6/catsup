version: '3.8'

services:
  frontend:
    image: niquinpro1/catsup-frontend:latest
    restart: always
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    environment:
      - TZ=America/Santiago
    deploy:
      resources:
        limits:
          memory: 256M
  
  multimedia:
    image: felinoi/catsup-multimedia:latest
    restart: always
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    environment:
#      - AZURE_ACCOUNT_NAME=tu_nombre_cuenta_aqui
#      - AZURE_ACCOUNT_KEY=ESTO_ES_LO_QUE_VA_A_SER_EVALUADO
#      - AZURE_CONTAINER=nombre_contenedor
      - DB_ENGINE=django.db.backends.postgresql
      - DB_HOST={{ db_host }}
      - DB_USER={{ db_user }}
      - DB_PASSWORD={{ db_password }}
      - DB_NAME={{ db_name }}
      - SECRET_KEY={{ secret_key }}
      - DEBUG=True
      - USE_S3=False
      - TZ=America/Santiago
    deploy:
      resources:
        limits:
          memory: 256M

  login:
    image: felinoi/catsup-login:latest
    restart: always
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/"]
      interval: 30s
      timeout: 10s
      retries: 3
    environment:
      - DB_ENGINE=django.db.backends.postgresql
      - DB_HOST={{ db_host }}
      - DB_USER={{ db_user }}
      - DB_PASSWORD={{ db_password }}
      - DB_NAME={{ db_name }}
      - SECRET_KEY={{ secret_key }}
      - DEBUG=True
      - USE_S3=False
      - TZ=America/Santiago
    deploy:
      resources:
        limits:
          memory: 256M

  ranking:
    image: niquinpro1/catsup-ranking:latest
    restart: always
    logging: 
      driver: "json-file"
      options: 
        max-size: "10m"
        max-file: "3"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/"]
      interval: 30s
      timeout: 10s
      retries: 3
    environment:
      - DB_ENGINE=django.db.backends.postgresql
      - DB_HOST={{ db_host }}
      - DB_USER={{ db_user }}
      - DB_PASSWORD={{ db_password }}
      - DB_NAME={{ db_name }}
      - SECRET_KEY={{ secret_key }}
      - DEBUG=True
      - USE_S3=False
      - TZ=America/Santiago
    deploy:
      resources:
        limits:
          memory: 256M

  comentarios:
    image: niquinpro1/catsup-comentarios:latest
    restart: always
    logging: 
      driver: "json-file"
      options: 
        max-size: "10m"
        max-file: "3"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/"]
      interval: 30s
      timeout: 10s
      retries: 3
    environment:
      - DB_ENGINE=django.db.backends.postgresql
      - DB_HOST={{ db_host }}
      - DB_USER={{ db_user }}
      - DB_PASSWORD={{ db_password }}
      - DB_NAME={{ db_name }}
      - SECRET_KEY={{ secret_key }}
      - DEBUG=True
      - USE_S3=False
      - TZ=America/Santiago
    deploy:
      resources:
        limits:
          memory: 256M
  
  nginx:
    image: nginx:latest
    container_name: nginx_proxy
    restart: always
    logging: 
      driver: "json-file"
      options: 
        max-size: "10m"
        max-file: "3"
    environment:
      - TZ=America/Santiago
    ports:
      - "80:80"
    volumes:
      - ./default.conf:/etc/nginx/conf.d/default.conf
    depends_on:
      frontend:
        condition: service_started
      multimedia:
        condition: service_started
      login:
        condition: service_healthy
      ranking:
        condition: service_healthy
      comentarios:
        condition: service_healthy